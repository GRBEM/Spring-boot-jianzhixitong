<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.JianzhipingjiaDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.JianzhipingjiaEntity" id="jianzhipingjiaMap">
        <result property="pingjiamingcheng" column="pingjiamingcheng"/>
        <result property="gangweimingcheng" column="gangweimingcheng"/>
        <result property="pingjiatupian" column="pingjiatupian"/>
        <result property="pingfenxinxi" column="pingfenxinxi"/>
        <result property="pingjiaxinxi" column="pingjiaxinxi"/>
        <result property="qiyemingcheng" column="qiyemingcheng"/>
        <result property="pingjiariqi" column="pingjiariqi"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="crossuserid" column="crossuserid"/>
        <result property="crossrefid" column="crossrefid"/>
        <result property="shhf" column="shhf"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.JianzhipingjiaVO" >
		SELECT * FROM jianzhipingjia  jianzhipingjia         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.JianzhipingjiaVO" >
		SELECT  jianzhipingjia.* FROM jianzhipingjia  jianzhipingjia 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.JianzhipingjiaView" >

		SELECT  jianzhipingjia.* FROM jianzhipingjia  jianzhipingjia 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.JianzhipingjiaView" >
		SELECT * FROM jianzhipingjia  jianzhipingjia <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM jianzhipingjia
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM jianzhipingjia
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM jianzhipingjia
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM jianzhipingjia
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM jianzhipingjia
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
